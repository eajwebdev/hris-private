# EAJ HRIS — production environment template.
# Copy to .env on the server and fill in. Never commit the filled-in file.

# --- App -------------------------------------------------------------------
APP_NAME="EAJ HRIS"
APP_ENV=production
# MUST be false. With APP_DEBUG=true, an unhandled error returns a stack trace
# with absolute file paths and query fragments to the browser.
APP_DEBUG=false
APP_URL=https://hris.example.com

# Generate on the server: php artisan key:generate
APP_KEY=

# --- Database --------------------------------------------------------------
# Use a dedicated DB user with rights only on this schema — never root.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=db_hris
DB_USERNAME=hris_app
DB_PASSWORD=

# --- Sessions / auth -------------------------------------------------------
# The SPA signs in with Sanctum's httpOnly SESSION COOKIE, not a bearer token in
# localStorage — so these are auth settings, not just tuning.
SESSION_DRIVER=database

# MUST be true over HTTPS: without it the session cookie is sent in clear text.
SESSION_SECURE_COOKIE=true

# Blocks the cookie on cross-site requests, which is the CSRF backstop.
SESSION_SAME_SITE=lax

# Set to the app's own domain (leading dot only if you need subdomains to share it).
SESSION_DOMAIN=hris.example.com

# Hosts allowed to hold a session. Sanctum ALSO trusts the app's own host
# automatically (config/sanctum.php), so this only needs entries for a frontend
# served from a *different* origin than the API. Match host AND port exactly.
SANCTUM_STATEFUL_DOMAINS=hris.example.com

CACHE_STORE=database

# Notifications are written in-app synchronously today. Once mail is wired,
# this needs a running worker: php artisan queue:work --daemon
QUEUE_CONNECTION=database

# --- Mail ------------------------------------------------------------------
# `log` means nothing is ever actually sent. Set a real transport before
# go-live or employees will never be emailed about approvals or payslips.
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hris@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Uploads ---------------------------------------------------------------
# Two disks, deliberately:
#   public  — employee avatars + branding logo only. Served straight off
#             public/storage. Run once on the server: php artisan storage:link
#   private — 201 documents, applicant CVs, medical certificates, punch photos.
#             Stored under storage/app/private and NEVER web-served; the app hands
#             them out as short-lived signed URLs (App\Support\PrivateFile).
#
# Confirm the web root is public/ and that storage/ is not reachable over HTTP.
# This only sets the *default* disk; both are addressed by name in code.
FILESYSTEM_DISK=local

# --- Google sign-in --------------------------------------------------------
# The "Continue with Google" button is always shown on the login page; until these
# are filled in it bounces back with a "not set up yet" message instead of failing.
#
# Google only ever matches an EXISTING, active user by email — it never creates an
# account. The redirect URI must match the one registered in the Google console
# byte for byte, including scheme and any trailing path.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://hris.example.com/auth/google/callback
